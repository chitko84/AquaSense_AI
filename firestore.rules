rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'aiuworkproject@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin', 'verified_responder'];
    }

    function isValidFloodReport(data) {
      return data.keys().hasAll(['userId', 'locationName', 'severity', 'status']) &&
             data.userId == request.auth.uid &&
             data.severity in ['Low', 'Medium', 'High', 'Critical'] &&
             data.status in ['Pending', 'Verified', 'Rejected', 'Resolved'];
    }

    function isValidPostFloodImpactReport(data) {
      return data.keys().hasAll(['userId', 'relatedIncidentId', 'locationName', 'floodDate', 'reportedBy', 'status']) &&
             data.userId == request.auth.uid &&
             data.status in ['Draft', 'Submitted', 'Reviewed', 'Archived'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'location']) &&
                      isValidUser(incoming());
    }

    match /floodReports/{reportId} {
      allow read: if true; // Public safety information
      allow create: if isSignedIn() && isValidFloodReport(incoming());
      allow update: if isAdmin() || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['description', 'photoUrl']) &&
        isValidFloodReport(incoming())
      );
      allow delete: if isAdmin();
    }

    match /postFloodImpactReports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPostFloodImpactReport(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /shelters/{shelterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /familyCheckIns/{checkInId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId) || isAdmin();
    }

    match /riskPredictions/{predictionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
